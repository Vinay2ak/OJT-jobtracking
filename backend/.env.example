# ===========================================
# Django Core Settings
# ===========================================
DJANGO_SECRET_KEY=your-super-secret-key-here
DJANGO_DEBUG=False
DJANGO_ALLOWED_HOSTS=your-domain.com,www.your-domain.com
DJANGO_LOG_LEVEL=INFO

# ===========================================
# Database (Option 1: Full URL - recommended for cloud platforms)
# ===========================================
DATABASE_URL=postgresql://user:password@host:5432/dbname

# ===========================================
# Database (Option 2: Individual fields - used if DATABASE_URL is empty)
# ===========================================
# DB_NAME=jobportal
# DB_USER=postgres
# DB_PASSWORD=your-db-password
# DB_HOST=localhost
# DB_PORT=5432

# ===========================================
# Email Configuration (Gmail SMTP)
# ===========================================
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=your-email@gmail.com
EMAIL_HOST_PASSWORD=your-app-password
DEFAULT_FROM_EMAIL=your-email@gmail.com

# ===========================================
# Redis (for WebSocket channel layers in production)
# Leave empty to use InMemory channel layer
# ===========================================
REDIS_URL=

# ===========================================
# JWT Token Lifetimes (in days)
# ===========================================
JWT_ACCESS_DAYS=30
JWT_REFRESH_DAYS=90

# ===========================================
# CORS (comma-separated frontend URLs)
# ===========================================
CORS_ALLOW_ALL_ORIGINS=True
CORS_ALLOWED_ORIGINS=https://your-frontend.com,https://www.your-frontend.com

# ===========================================
# Security (enable for HTTPS deployments)
# ===========================================
SECURE_SSL_REDIRECT=False
