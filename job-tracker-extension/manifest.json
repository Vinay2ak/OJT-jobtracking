{
  "manifest_version": 3,
  "name": "Job Application Tracker",
  "version": "2.0",
  "description": "Automatically track job applications from LinkedIn, Naukri & Indeed in real-time",

  "permissions": ["storage", "activeTab", "notifications"],

  "host_permissions": [
    "http://127.0.0.1:8000/*",
    "https://www.linkedin.com/*",
    "https://www.naukri.com/*",
    "https://www.indeed.com/*",
    "https://in.indeed.com/*",
    "https://ojt-jobtracking-1906.onrender.com/*"
  ],

  "background": {
    "service_worker": "background.js"
  },

  "action": {
    "default_popup": "popup.html",
    "default_title": "Job Tracker"
  },

  "content_scripts": [
    {
      "matches": ["https://www.linkedin.com/*"],
      "js": ["content-linkedin.js"],
      "run_at": "document_idle"
    },
    {
      "matches": ["https://www.linkedin.com/my-items/saved-jobs/*"],
      "js": ["sync-linkedin.js"],
      "run_at": "document_idle"
    },
    {
      "matches": ["https://www.naukri.com/*"],
      "js": ["content-naukri.js"],
      "run_at": "document_idle"
    },
    {
      "matches": ["https://www.naukri.com/mnjuser/app/*"],
      "js": ["sync-naukri.js"],
      "run_at": "document_idle"
    },
    {
      "matches": ["https://www.indeed.com/*", "https://in.indeed.com/*"],
      "js": ["content-indeed.js"],
      "run_at": "document_idle"
    }
  ],

  "icons": {
    "48": "icon48.png",
    "128": "icon128.png"
  }
}